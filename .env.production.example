# ---------------------------------------------------------------------------
# Production environment for Nexus. Copy to ".env" on your server and fill in
# REAL values. NEVER commit the real .env to git.
#
# Generate strong secrets with:
#   openssl rand -base64 48     (for JWT_SECRET)
#   openssl rand -base64 24     (for POSTGRES_PASSWORD)
# ---------------------------------------------------------------------------

# --- Database (kept private, never exposed to the internet) ---
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_ME_long_random_password
POSTGRES_DB=nexus
DATABASE_URL=postgresql://nexus:CHANGE_ME_long_random_password@db:5432/nexus?schema=public

# --- Auth ---
JWT_SECRET=CHANGE_ME_at_least_48_random_characters

# --- Your domains (must match the Caddyfile) ---
CLIENT_ORIGIN=https://app.example.com
VITE_API_URL=https://api.example.com
VITE_SOCKET_URL=https://api.example.com

# --- Media ---
MEDIA_STORAGE_PROVIDER=local
# MEDIA_PUBLIC_BASE_URL=https://api.example.com/uploads

# --- Email verification (required in production so codes actually send) ---
SMTP_HOST=smtp.youremail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey-or-username
SMTP_PASS=CHANGE_ME
SMTP_FROM=Nexus <no-reply@yourdomain.com>

# --- Calls: STUN is fine for most networks. Add a TURN server (e.g. coturn)
#     if users are behind strict firewalls/symmetric NAT. ---
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# TURN_URLS=turn:turn.example.com:3478
# TURN_USERNAME=nexus
# TURN_CREDENTIAL=CHANGE_ME
