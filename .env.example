POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_password
POSTGRES_DB=nexus
DATABASE_URL=postgresql://nexus:nexus_dev_password@db:5432/nexus?schema=public
JWT_SECRET=replace-this-with-a-long-random-secret
API_PORT=4000
WEB_PORT=5173
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
CLIENT_ORIGIN=http://localhost:5173
MEDIA_STORAGE_PROVIDER=local
# Optional CDN/object-storage public base URL for original-quality media delivery.
# MEDIA_PUBLIC_BASE_URL=https://cdn.example.com/nexus

# --- Email verification (SMTP) ---
# If these are unset, verification codes are printed to the API console
# (fine for development). Set them in production to actually send emails.
# SMTP_HOST=smtp.youremail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey-or-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Nexus <no-reply@yourdomain.com>

# --- Calls (Phase 3): WebRTC ICE configuration ---
# Comma-separated STUN servers (public defaults work for most NATs).
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# Optional TURN relay for symmetric NATs / networks that block P2P UDP.
# Run e.g. coturn and point these at it for reliable calls behind firewalls.
# TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# TURN_USERNAME=nexus
# TURN_CREDENTIAL=replace-with-turn-secret
