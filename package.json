{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "description": "Nexus Phase 1 secure realtime messaging MVP",
  "scripts": {
    "dev": "pnpm --parallel --filter @nexus/api --filter @nexus/web dev",
    "build": "pnpm --recursive build",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "db:generate": "pnpm --filter @nexus/api prisma generate",
    "db:migrate": "pnpm --filter @nexus/api prisma migrate dev",
    "db:deploy": "pnpm --filter @nexus/api prisma migrate deploy"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
